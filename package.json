{
  "name": "@ziyu0123/nanoui",
  "version": "1.0.0",
  "description": "Vue 3 Component Library",
  "type": "module",
  "author": "April Liu",
  "license": "MIT",
  "keywords": [
    "Component",
    "UI",
    "Vue3"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ziyu-0123/NanoUI.git"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "dist/index.css"
  ],
  "main": "./dist/umd/nano-element.umd.cjs",
  "module": "./dist/es/nano-element.js",
  "types": "./dist/es/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/es/nano-element.js",
      "require": "./dist/umd/nano-element.umd.cjs"
    },
    "./dist/": {
      "import": "./dist/",
      "require": "./dist/"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build-only && npm run move-style",
    "preview": "vite preview",
    "build-only": "run-p build-es build-umd",
    "build-umd": "vite build --config vite.umd.config.ts",
    "build-es": "vite build --config vite.es.config.ts",
    "move-style": "move-file dist/es/index.css dist/index.css",
    "type-check": "vue-tsc --build",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.1.3",
    "@popperjs/core": "^2.11.8",
    "async-validator": "^4.2.5",
    "lodash-es": "^4.18.1"
  },
  "peerDependencies": {
    "vue": "^3.5.31"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vitepress-demo-preview/component": "^2.6.2",
    "@vitepress-demo-preview/plugin": "^1.4.1",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.1.0",
    "eslint-plugin-oxlint": "~1.57.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "move-file-cli": "^3.0.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.57.0",
    "postcss-color-function": "^4.1.0",
    "postcss-color-mix": "^1.1.0",
    "postcss-custom-properties": "^15.0.1",
    "postcss-each": "^1.1.0",
    "postcss-each-variables": "^0.3.0",
    "postcss-for": "^2.1.1",
    "postcss-nested": "^7.0.2",
    "typescript": "~6.0.0",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^5.0.1",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitepress": "^2.0.0-alpha.17",
    "vitest": "^4.1.3",
    "vue-tsc": "^3.2.6",
    "vue": "^3.5.31"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
